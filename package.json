{
  "name": "revo-browser",
  "version": "1.0.0",
  "description": "Revo - Modern Lightweight Firefox-based Browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --linux deb --win",
    "build:linux": "electron-builder --linux deb",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --linux deb --win"
  },
  "build": {
    "appId": "com.revo.browser",
    "productName": "Revo",
    "directories": {
      "output": "export"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!.git/**",
      "!.gitignore"
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Network",
      "maintainer": "SegMind25"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SegMind25/Revo.git"
  },
  "keywords": [],
  "author": "SegMind25",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SegMind25/Revo/issues"
  },
  "homepage": "https://github.com/SegMind25/Revo#readme",
  "dependencies": {},
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1"
  }
}
